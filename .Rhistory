# Clean the data
movie_ts <- barbie_data_raw |>
# Select only the relevant columns (Date and Daily Gross)
select(Date, Daily) |>
# Parse the currency into numeric values
mutate(
Gross = parse_number(Daily),
# Box Office mojo dates often look like "Jul 21". We need to add the year.
# Assuming the movie came out in 2023 for this example:
Date = paste(Date, "2023"),
Date = mdy(Date)
) |>
# Drop rows where Date didn't parse or Gross is NA
drop_na(Date, Gross) |>
# Filter to the first 30+ days to ensure we have enough data for seasonality
slice(1:40) |>
# Convert to a tsibble
as_tsibble(index = Date)
# Check for implicit gaps (days the movie wasn't reported)
has_gaps(movie_ts)
# If there are gaps, fill them (optional but good practice for fpp3)
# movie_ts <- fill_gaps(movie_ts, Gross = 0)
has_gaps(movie_ts)
